# ledger-svc .env.example — service-internal knobs.
#
# Loaded ON TOP OF the root .env (which carries DATABASE_URL / REDIS_URL /
# KAFKA_BROKERS). godotenv is non-overriding, so a shell export beats
# either file — the precedence is: shell > root .env > this file >
# struct defaults.
#
# Copy to apps/ledger-svc/.env. Production never reads .env files
# (APP_ENV=production gates the loader off in internal/config).

# --- Process ------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=debug

# --- gRPC ---------------------------------------------------------------------
GRPC_ADDR=:9090
# How long GracefulStop waits for in-flight RPCs before hard-stopping.
GRPC_SHUTDOWN_TIMEOUT=30s

# --- Postgres pool tuning -----------------------------------------------------
# Sizing rule of thumb for the OLTP write path:
#
#   MaxConns ≥ TPS × p99_tx_seconds × safety_factor(2)
#
# At 10K TPS with 5ms p99 tx, that's ~100 active connections; default 120
# leaves headroom. PG's max_connections must accommodate the sum across
# replicas + outbox workers (the server adds OUTBOX_WORKERS to its pool
# size on top because workers hold a conn for the duration of a drain).
DATABASE_MAX_CONNS=120
DATABASE_MIN_CONNS=20
DATABASE_CONN_MAX_LIFE=1h
DATABASE_CONN_MAX_IDLE=30m
# Per-call cap on Acquire wait — fail fast on pool starvation rather than
# stretching p99 silently. Keep strictly less than the typical client
# deadline (which the BFF sets) so the request still has time to surface
# the error to the caller.
DATABASE_ACQUIRE_TIMEOUT=500ms

# --- Metrics -----------------------------------------------------------------
# Prometheus exposition; empty disables the listener.
METRICS_ADDR=:9100

# --- Kafka producer -----------------------------------------------------------
KAFKA_CLIENT_ID=ledger-svc

# --- Outbox -------------------------------------------------------------------
OUTBOX_TOPIC=fintech.ledger.transactions
# In-process worker fleet size. Bound by the Postgres pool headroom above.
OUTBOX_WORKERS=4

# --- Edge identity ------------------------------------------------------------
# ledger-svc is internal-only: the BFF validates the caller's JWT and
# forwards the resolved actor identity as headers. The interceptor reads
# x-tenant-id, x-actor-subject, x-actor-session and rejects any RPC
# missing the required pair (tenant + subject). Service-mesh / network
# policy keeps non-BFF callers off the listener; nothing in this process
# defends against a forged header from inside the trust boundary.
#
# No env knobs needed — the protocol is fixed and the public-method
# bypass list (health, reflection) is hardcoded in interceptors.

# --- OpenTelemetry ------------------------------------------------------------
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to install the no-op tracer
# (zero overhead). The W3C TraceContext propagator is installed regardless,
# so trace ids still flow through gRPC metadata to downstream services.
#
# To export to a local collector:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#   OTEL_EXPORTER_OTLP_INSECURE=true
#
OTEL_SERVICE_NAME=ledger-svc
# Sampler ∈ {always_on, always_off, traceidratio, parentbased_traceidratio}.
OTEL_TRACES_SAMPLER=always_on
OTEL_TRACES_SAMPLER_ARG=0.1

# Dev-only: also pretty-print spans to stdout. NEVER enable in production
# (per-span fsync to stdout).
OBS_TRACE_DEBUG=false
