# Root .env.example — TRULY shared infra coordinates only.
#
# This file is owned by docker-compose.yml and the Makefile. Things
# that genuinely cross service boundaries (Kafka cluster, shared
# Redis, observability collectors) live here. Things that look
# shared but are per-service in good design (each service's
# Postgres) live in the per-service .env files.
#
# ## What "per-service in good design" means
#
# Each service owns its own internal/config package (Go's internal/
# rule enforces this — `apps/gateway-svc/cmd/server/main.go` cannot
# import `apps/ledger-svc/internal/config`). And each service that
# holds domain state owns its OWN Postgres cluster — for bounded-
# context isolation, failure isolation, independent tuning, schema
# autonomy, and PCI / regulatory blast-radius reasons. See
# apps/gateway-svc/docs/charter.md → "Storage isolation" for the
# full rationale.
#
# So:
#
#   - DATABASE_URL → per-service. Each service's .env declares its
#     own (LEDGER_DATABASE_URL, GATEWAY_DATABASE_URL when that lands).
#     Root .env carries them as a coordination point IF you want one
#     place to grep, but the source-of-truth is per-service.
#   - POSTGRES_USER/PASSWORD/DB → per-PG-instance. docker-compose
#     reads them via per-service-prefixed names (LEDGER_POSTGRES_*,
#     GATEWAY_POSTGRES_*) when more than one stateful service exists.
#   - KAFKA_BROKERS → genuinely shared. One cluster, distinct topics
#     per service. Stays here.
#   - REDIS_URL → can stay shared if services namespace keys by
#     prefix. If a service genuinely needs its own Redis, it follows
#     the same per-service rule.
#
# Copy to .env (Makefile and docker-compose auto-load it).

# --- Postgres (ledger-svc) ---------------------------------------------------
# Each stateful service has its own PG instance. Today only ledger-svc
# is stateful; LEDGER_DATABASE_URL is duplicated as DATABASE_URL for
# backward compatibility with the current internal/config tag.
# When gateway-svc lands, GATEWAY_DATABASE_URL gets added below and
# the docker-compose stack grows a second postgres service.
#
# LEDGER_POSTGRES_* mirror the same values for docker-compose's
# `postgres` service init env — keep them in sync if you change creds.
DATABASE_URL=postgres://phuong_dev:ledger_secret@localhost:5432/ledger_db?sslmode=disable
LEDGER_DATABASE_URL=postgres://phuong_dev:ledger_secret@localhost:5432/ledger_db?sslmode=disable
LEDGER_POSTGRES_USER=phuong_dev
LEDGER_POSTGRES_PASSWORD=ledger_secret
LEDGER_POSTGRES_DB=ledger_db

# Aliases for docker-compose.yml's current `postgres` service. When
# the second PG service lands these unprefixed names retire.
POSTGRES_USER=phuong_dev
POSTGRES_PASSWORD=ledger_secret
POSTGRES_DB=ledger_db

# --- Postgres (gateway-svc) — uncomment when gateway-svc moves past stub -----
# GATEWAY_DATABASE_URL=postgres://phuong_dev:gateway_secret@localhost:5433/gateway_db?sslmode=disable
# GATEWAY_POSTGRES_USER=phuong_dev
# GATEWAY_POSTGRES_PASSWORD=gateway_secret
# GATEWAY_POSTGRES_DB=gateway_db

# --- Redis (shared cluster, per-service keyspace prefix) ---------------------
REDIS_URL=redis://localhost:6379/0

# --- Kafka / Redpanda (shared cluster, distinct topics per service) ----------
# Comma-separated for multi-broker; consumed by both confluent-kafka-go
# (joined back to a string) and rpk for topic admin.
KAFKA_BROKERS=localhost:9092
