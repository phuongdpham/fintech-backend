{
  "name": "proto-schemas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "shared/proto",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint",
        "cwd": "shared/proto"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf generate",
        "cwd": "shared/proto"
      },
      "outputs": ["{workspaceRoot}/libs/go/proto-gen/fintech"]
    }
  },
  "tags": ["lang:proto", "scope:schema"]
}
