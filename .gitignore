# Build artifacts
node_modules/
dist/
coverage/
.nx/
*.log

# Go binaries / test outputs
**/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
# Stray `go build` outputs in service dirs (e.g. apps/<svc>/<svc>) when
# someone forgets the -o flag. The Nx targets all use -o ../../dist/...,
# so these only ever appear by accident.
apps/*/server
apps/*/reconciler
apps/*/migrate
apps/*/loadtest

# Load-test seed output — generated by `make loadtest-seed`, large
# (10K tenants × 100 accounts ~= 8MB). Reproduce with the seeder.
apps/*/load/fixtures.json

# pprof captures — per-developer; reproduce with `make profile-*`.
apps/*/profiles/

# Env files — only .example variants are committed
.env
**/.env
!.env.example
!**/.env.example

# Editor / IDE
.idea/
.vscode/
.DS_Store

# Claude Code per-user state — NOT shared. Everything else under .claude/
# (CLAUDE.md, skills/, agents/, commands/) is tracked so the team gets
# shared instructions and skills.
.claude/settings.local.json
.claude/worktrees/

# Archive artifacts
*.tar
*.tar.*
*.tgz
*.zip
*.sig
